API_HOST=127.0.0.1
API_PORT=4017
API_CORS_ORIGIN=*

# Development Postgres (PostGIS-enabled). Start with `npm run db:up`.
POSTGRES_PORT=5433
DATABASE_URL=postgres://happened:happened@localhost:5433/happened

# Local-first media storage. Keep this as local while the Mac mini is the preview server.
# DEPRECATED in S3 sprint — superseded by S3_* (MinIO) below.
MEDIA_STORAGE_DRIVER=local
MEDIA_LOCAL_DIR=.local/uploads
MEDIA_MAX_BYTES=41943040
# Optional. Leave blank for the API to serve /uploads through the same public URL.
MEDIA_PUBLIC_BASE_URL=

# OAuth (S2/S3 — currently UI scaffold only, leave blank).
# Google OAuth client ID for expo-auth-session (web client ID works for Expo Go).
EXPO_PUBLIC_GOOGLE_CLIENT_ID=
# Apple Services ID (used as web/Android fallback for Apple Sign-In).
EXPO_PUBLIC_APPLE_SERVICES_ID=

# ---- S2 parity infra ----------------------------------------------------------

# MinIO (S3-compatible object storage). Defaults match docker-compose.dev.yml.
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# Object storage client (server reads these). Dev points at the local MinIO.
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=happened-media-dev
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
# Path-style URL works against MinIO. Set to bucket-virtual base URL when going to AWS.
S3_PUBLIC_URL_BASE=http://localhost:9000/happened-media-dev
S3_FORCE_PATH_STYLE=1

# MailHog (dev SMTP). Container ports from docker-compose.dev.yml.
MAILHOG_SMTP_PORT=1025
MAILHOG_UI_PORT=8025

# SMTP client (server reads these). Dev points at MailHog (no auth).
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=0
SMTP_USER=
SMTP_PASS=
SMTP_FROM=happened <no-reply@happened.local>
