API_HOST=127.0.0.1
API_PORT=4017
API_CORS_ORIGIN=*

# Development Postgres. Start with `npm run db:up`.
POSTGRES_PORT=5433
DATABASE_URL=postgres://happened:happened@localhost:5433/happened

# Local-first media storage. Keep this as local while the Mac mini is the preview server.
MEDIA_STORAGE_DRIVER=local
MEDIA_LOCAL_DIR=.local/uploads
MEDIA_MAX_BYTES=41943040
# Optional. Leave blank for the API to serve /uploads through the same public URL.
MEDIA_PUBLIC_BASE_URL=
