{
  "name": "happened",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "node scripts/dev.mjs",
    "dev": "node scripts/dev.mjs",
    "android": "node scripts/dev.mjs --android",
    "ios": "node scripts/dev.mjs --ios",
    "web": "node scripts/dev.mjs --web",
    "api": "tsx server/index.ts",
    "api:dev": "tsx watch server/index.ts",
    "db:up": "docker compose -f docker-compose.dev.yml up -d",
    "db:migrate": "tsx server/migrate.ts",
    "db:reset": "echo 'Use docker compose -f docker-compose.dev.yml down -v to wipe volumes (DESTRUCTIVE)'",
    "test:server": "tsx server/__tests__/parity.test.ts",
    "test:local": "node scripts/test-local.mjs",
    "test:iphone": "node scripts/test-local.mjs --native",
    "test:public": "node scripts/test-public.mjs",
    "test:tailscale": "node scripts/test-tailscale.mjs",
    "preview:local": "node scripts/serve-preview.mjs",
    "qa:public": "node scripts/qa-public.mjs",
    "capture:prototype": "node scripts/capture-prototype.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1037.0",
